---
/**
 * Turnstile + ハニーポット付きお問い合わせフォーム
 * PUBLIC_TURNSTILE_SITE_KEY を .env に設定（Cloudflare Pages の Variables でも可）
 */
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
---

<form id="contact-form" class="contact-form" action="/api/contact" method="POST">
	<input type="text" name="_subject" value="Bristlecone お問い合わせ" hidden />
	<!-- ハニーポット: 人間は触らない。bot が埋めるとサーバー側でブロック -->
	<div class="hp-wrap" aria-hidden="true">
		<label for="website">Website</label>
		<input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
	</div>
	<div class="form-row">
		<label for="name">お名前</label>
		<input type="text" id="name" name="name" required placeholder="山田 太郎" />
	</div>
	<div class="form-row">
		<label for="email">メールアドレス</label>
		<input type="email" id="email" name="_replyto" required placeholder="example@email.com" />
	</div>
	<div class="form-row">
		<label for="message">お問い合わせ内容 <span class="required">*</span></label>
		<textarea id="message" name="message" rows="6" required placeholder="ご用件をご記入ください（日本語でご記入ください）"></textarea>
	</div>
	<div class="form-row turnstile-row">
		<label class="visually-hidden">自動確認</label>
		<div class="turnstile-wrap">
			{siteKey ? (
				<div
					class="cf-turnstile"
					data-sitekey={siteKey}
					data-theme="light"
					data-size="normal"
				/>
			) : (
				<p class="turnstile-warning">Turnstile の site key が未設定です（PUBLIC_TURNSTILE_SITE_KEY）</p>
			)}
		</div>
	</div>
	<div class="form-actions">
		<button type="submit" class="btn btn-submit">送信</button>
	</div>
</form>

<script is:inline>
	if (typeof window !== 'undefined') {
		var s = document.createElement('script');
		s.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
		s.async = true;
		s.defer = true;
		document.head.appendChild(s);
	}
</script>

<style>
	.contact-form {
		margin: 0 0 2rem;
	}

	/* ハニーポット: 画面外に配置（CSS で非表示） */
	.hp-wrap {
		position: absolute;
		left: -9999px;
		top: auto;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.hp-wrap input {
		position: absolute;
		left: 0;
		top: 0;
		width: 240px;
		height: 1px;
		opacity: 0;
	}

	.form-row {
		margin-bottom: 1.25rem;
	}

	.form-row label {
		display: block;
		font-size: 0.9375rem;
		font-weight: 600;
		margin-bottom: 0.35rem;
		color: #374151;
	}

	.required {
		color: #b91c1c;
	}

	.form-row input,
	.form-row textarea {
		width: 100%;
		max-width: 100%;
		box-sizing: border-box;
		padding: 0.5rem 0.75rem;
		font-size: 1rem;
		font-family: inherit;
		border: 1px solid #d1d5db;
		border-radius: 0.375rem;
	}

	.form-row textarea {
		resize: vertical;
		min-height: 8rem;
	}

	.form-row input:focus,
	.form-row textarea:focus {
		outline: none;
		border-color: #2d3a4a;
	}

	.turnstile-row {
		margin-bottom: 1rem;
	}

	.turnstile-wrap {
		min-height: 65px;
	}

	.turnstile-warning {
		font-size: 0.875rem;
		color: #b45309;
		margin: 0;
	}

	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.form-actions {
		margin-top: 1.5rem;
	}

	.btn {
		display: inline-block;
		padding: 0.65rem 1.5rem;
		font-size: 0.9375rem;
		font-weight: 600;
		font-family: inherit;
		border: none;
		border-radius: 0.375rem;
		cursor: pointer;
	}

	.btn-submit {
		background: #2d3a4a;
		color: #fff;
	}

	.btn-submit:hover:not(:disabled) {
		background: #232f3d;
	}

	.btn-submit:disabled {
		opacity: 0.7;
		cursor: not-allowed;
	}
</style>
